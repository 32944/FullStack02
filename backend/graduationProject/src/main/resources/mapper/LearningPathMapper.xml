<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.graduation.mapper.LearningPathMapper">

    <resultMap id="BaseResultMap" type="com.itheima.graduation.entity.LearningPath">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="target" property="target"/>
        <result column="content" property="content"/>
        <result column="path" property="ossUrl"/>
        <result column="type" property="category"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, target, content, path, type, create_time
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM learnning_path
        ORDER BY create_time DESC
    </select>

    <select id="selectByCategory" parameterType="String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM learnning_path
        WHERE type = #{category}
        ORDER BY create_time DESC
    </select>

    <select id="selectById" parameterType="Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM learnning_path
        WHERE id = #{id}
    </select>

    <select id="selectCategories" resultType="String">
        SELECT DISTINCT type FROM learnning_path ORDER BY type
    </select>

</mapper>
